{
  "name": "kindled",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "complexity": "lizard src/app src/capture src/hearth src/ritual src/ui/icons src/main.ts -l typescript -x '*test*' -C 12",
    "native:dev": "zig build run",
    "native:build": "zig build -Doptimize=ReleaseSafe",
    "supabase:db:push": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy provision-vault --no-verify-jwt && supabase functions deploy get-sync-config --no-verify-jwt"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.104.0",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "buffer": "^6.0.3",
    "grab-bcv": "^0.1.5",
    "solid-js": "^1.9.12",
    "wa-sqlite": "^1.0.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@tursodatabase/api": "^2.0.0",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "agentation": "^3.0.2",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.60.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4"
  }
}
